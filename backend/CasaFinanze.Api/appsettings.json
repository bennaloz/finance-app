{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ConnectionStrings:Default è opzionale: se assente, Program.cs sceglie il path del DB
  // (/home/data su Azure App Service, ./data in locale). Per forzarlo imposta l'App Setting
  // ConnectionStrings__Default, es: "Data Source=/home/data/casafinanze.db".
  "ConnectionStrings": {
  },

  "Jwt": {
    // ATTENZIONE: la chiave NON va messa qui (è un segreto, finirebbe in git).
    // Sviluppo: valorizzata in appsettings.Development.json.
    // Produzione (Azure): impostarla come App Setting/variabile d'ambiente "Jwt__Key" (min 32 caratteri).
    "Key": "",
    "Issuer": "CasaFinanze"
  },

  // Origini consentite per il CORS (frontend su Azure Static Web Apps).
  // In produzione impostare l'URL dello Static Web App come App Setting Cors__AllowedOrigins__0,
  // es: "https://<nome>.azurestaticapps.net". In sviluppo vedi appsettings.Development.json.
  "Cors": {
    "AllowedOrigins": []
  }
}
